# metrics-agent environment variables
# Copy this file to .env and adjust values for local development.

# HTTP port the agent listens on. Default: 9100
PORT=9100

# Interval between metric scrapes, in seconds. Default: 10
SCRAPE_INTERVAL_SECONDS=10

# Logical environment label attached to every metric. Default: development
ENV=development

# Log format: "json" for structured JSON (recommended in production),
# anything else (or unset) for human-readable text. Default: text
LOG_FORMAT=text
